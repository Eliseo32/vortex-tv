{
  "expo": {
    "name": "SHAGOO!",
    "slug": "shagoo",
    "owner": "leonel322",
    "version": "1.0.0",
    "orientation": "landscape",
    "icon": "./assets/tv-banner.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050505"
    },
    "plugins": [
      "@react-native-tvos/config-tv",
      "react-native-video"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "banner": "./assets/tv-banner.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/tv-banner.png",
        "backgroundColor": "#050505"
      },
      "intentFilters": [
        {
          "action": "MAIN",
          "category": [
            "LEANBACK_LAUNCHER"
          ]
        }
      ],
      "package": "com.safft.shagoo",
      "permissions": [],
      "usesCleartextTraffic": true,
      "blockedPermissions": []
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "25efdbac-ca6d-4bad-b0cc-e6cd6a6a23d9"
      }
    }
  }
}
